
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Deny all reads and writes by default.
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to read their own user document
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
    }

    // Allow authenticated users to read product and location data
    match /products/{productId} {
      allow read: if request.auth != null;
    }
    match /locations/{locationId} {
      allow read: if request.auth != null;
    }
    match /movements/{movementId} {
        allow read: if request.auth != null;
    }
    match /audit_logs/{logId} {
        allow read: if request.auth != null;
    }
     match /export_logs/{logId} {
        allow read: if request.auth != null;
    }
    
    // Write access should be handled by secure server actions, not direct client writes.
    // Allow writes only from a secure environment (e.g., Cloud Functions or server actions).
    // For now, we will keep writes locked down until role-based logic is complete.
  }
}
