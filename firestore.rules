rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function isViewer() {
        return getUserRole(request.auth.uid) in ['viewer', 'manager', 'admin'];
    }
    
    function isManager() {
        return getUserRole(request.auth.uid) in ['manager', 'admin'];
    }

    function isAdmin() {
        return getUser-role(request.auth.uid) == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /products/{productId} {
      allow read: if isViewer();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }
    
    match /locations/{locationId} {
      allow read: if isViewer();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    match /movements/{movementId} {
      allow read: if isViewer();
      allow create: if isManager();
      // Movements are ledger entries and should not be updated or deleted by users.
      allow update, delete: if false; 
    }
    
    match /orders/{orderId} {
      allow read: if isViewer();
      allow create, update: if isManager();
      // Orders should likely be cancelled, not deleted.
      allow delete: if isAdmin(); 
    }
    
    match /audit_logs/{logId} {
      // Only admins can view the raw audit log for security.
      allow read, list: if isAdmin(); 
      // Logs are created by the system via server actions, not directly by clients.
      allow write: if false;
    }

    match /export_logs/{logId} {
       allow read: if isViewer();
       // Logs are created by the system via server actions.
       allow write: if false;
    }
  }
}
