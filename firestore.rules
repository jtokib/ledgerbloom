rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get the user's role from the 'users' collection.
    // It's safe to allow any authenticated user to read the users collection
    // as it's needed to determine their role for other rules.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Users can read their own user document.
    // Only admins can create, update, or delete user documents.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) == 'admin';
    }

    // Products can be read by any authenticated user.
    // Products can only be written by admins.
    match /products/{productId} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) == 'admin';
    }
    
    // Locations can be read by any authenticated user.
    // Locations can only be written by admins.
    match /locations/{locationId} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) == 'admin';
    }
    
    // Movements can be read by any authenticated user.
    // Movements can be created by managers and admins.
    match /movements/{movementId} {
      allow read: if request.auth != null;
      allow create: if getUserRole(request.auth.uid) in ['admin', 'manager'];
      allow update, delete: if getUserRole(request.auth.uid) == 'admin';
    }

    // Orders can be read by any authenticated user.
    // Orders can be created and updated by managers and admins.
    match /orders/{orderId} {
        allow read: if request.auth != null;
        allow create, update: if getUserRole(request.auth.uid) in ['admin', 'manager'];
        allow delete: if getUserRole(request.auth.uid) == 'admin';
    }
    
    // Export and Audit logs are sensitive and should only be readable by admins.
    // Only the system (via server actions) should be able to create them.
    match /export_logs/{logId} {
      allow read, write: if getUserRole(request.auth.uid) == 'admin';
    }
    
    match /audit_logs/{logId} {
      allow read, write: if getUserRole(request.auth.uid) == 'admin';
    }

  }
}
