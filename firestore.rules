
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to get user's role from the 'users' collection
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if a user is an admin
    function isAdmin() {
      return isAuthenticated() && getUserRole(request.auth.uid) == 'admin';
    }

    // Helper function to check if a user is a manager or admin
    function isManager() {
      let userRole = getUserRole(request.auth.uid);
      return isAuthenticated() && (userRole == 'manager' || userRole == 'admin');
    }
    
    // Users can read/update their own profile, admins can manage all users
    match /users/{userId} {
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      allow create, list, delete: if isAdmin();
    }
    
    // Products: Admins can do anything, others can only read.
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Locations: Admins can do anything, others can only read.
    match /locations/{locationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Orders: Managers/Admins can create/update, only Admins can delete. All authenticated can read.
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }
    
    // Movements: Created by the system (server actions), so we need to allow writes for authenticated users.
    // Reading should be allowed for all authenticated users.
    match /movements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Server actions run with user's auth context
      allow update, delete: if isAdmin(); // Only admins can correct movements
    }
    
    // Audit Logs: Only allow read access for admins to maintain integrity. Creation is server-side.
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Server actions run with user's auth context
      allow write: if false; // Disallow update/delete for everyone
    }

    // Export Logs: Same as audit logs.
    match /export_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Server actions run with user's auth context
      allow write: if false;
    }
  }
}
