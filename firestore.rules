
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isLoggedIn() && getRole(request.auth.uid) == 'admin';
    }

     function isManager() {
      return isLoggedIn() && (getRole(request.auth.uid) == 'manager' || isAdmin());
    }

    // Products can be read by any logged in user, but only modified by admins
    match /products/{productId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Locations can be read by any logged in user, but only modified by admins
    match /locations/{locationId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }
    
    // Users can only read their own user document
    match /users/{userId} {
      allow read: if isLoggedIn() && isOwner(userId);
      // Allow admins to create/update roles in the future.
      allow write: if isAdmin();
    }
    
    // Allow any authenticated user to read movements and audit logs
    match /movements/{movementId} {
      allow read: if isLoggedIn();
      // writes are handled by secure server actions only
      allow write: if false; 
    }

    match /audit_logs/{logId} {
      allow read: if isLoggedIn();
       // writes are handled by secure server actions only
      allow write: if false;
    }

    match /export_logs/{logId} {
      allow read: if isLoggedIn();
       // writes are handled by secure server actions only
      allow write: if false;
    }

     match /orders/{orderId} {
      allow read: if isLoggedIn();
      allow create, update: if isManager();
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
