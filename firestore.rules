rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to get the user's role from the 'users' collection.
    // This function is used in the rules for other collections.
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // Users can read any user document to check roles, but only admins or the user themselves can write.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || getUserRole(request.auth.uid) == 'admin';
    }

    // Products: Viewable by anyone, managed by admins.
    match /products/{productId=**} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) == 'admin';
    }

    // Locations: Viewable by anyone, managed by admins.
    match /locations/{locationId=**} {
      allow read: if request.auth != null;
      allow write: if getUserRole(request.auth.uid) == 'admin';
    }

    // Movements: Viewable by anyone, created by managers and admins. Cannot be edited or deleted.
    match /movements/{movementId} {
      allow read: if request.auth != null;
      allow create: if getUserRole(request.auth.uid) in ['admin', 'manager'];
      allow update, delete: if false; // Movements are immutable
    }

    // Orders: Viewable by anyone, managed by managers and admins.
    match /orders/{orderId=**} {
        allow read: if request.auth != null;
        allow write: if getUserRole(request.auth.uid) in ['admin', 'manager'];
    }

    // Audit Logs: Append-only for any authenticated user, readable only by admins.
    match /audit_logs/{logId} {
      allow read: if getUserRole(request.auth.uid) == 'admin';
      allow create: if request.auth != null;
      allow update, delete: if false; // Logs are immutable
    }

    // Export Logs: Append-only for any authenticated user, readable by admins and managers.
    match /export_logs/{logId} {
        allow read: if getUserRole(request.auth.uid) in ['admin', 'manager'];
        allow create: if request.auth != null;
        allow update, delete: if false; // Logs are immutable
    }
  }
}
