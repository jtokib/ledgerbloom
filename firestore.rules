rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user has the 'admin' role.
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Users can read their own user document.
      // Only admins can create, update, or delete user documents.
      allow read: if request.auth.uid == userId;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      // Anyone authenticated can read products.
      // Only admins can create, update, or delete products.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /locations/{locationId} {
       // Anyone authenticated can read locations.
      // Only admins can create, update, or delete locations.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Movements are more complex, for now, allow authenticated users to read.
    // Writes should be restricted based on role and context.
    match /movements/{movementId} {
      allow read: if request.auth != null;
      // Allow admins to create movements for now.
      allow create: if isAdmin();
      allow update, delete: if false; // Movements should be immutable
    }

    match /audit_logs/{logId} {
        // Only admins can read audit logs
        allow read: if isAdmin();
        // The system (via server actions) can create logs. No client writes.
        allow write: if false;
    }

    match /export_logs/{logId} {
        // Only admins can read export logs
        allow read: if isAdmin();
        // The system (via server actions) can create logs. No client writes.
        allow write: if false;
    }

    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
